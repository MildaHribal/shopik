# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (drizzle-orm)
DATABASE_URL=postgresql://user:password@localhost:5432/shopik

# ─── Better-auth ─────────────────────────────────────────────────────────────
# Generate a random 64+ char secret: `openssl rand -base64 48`
BETTER_AUTH_SECRET=change-me-generate-a-random-64-char-secret
BETTER_AUTH_URL=http://localhost:3000
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys — use LIVE keys in production
NUXT_STRIPE_SECRET_KEY=sk_test_your_key_here
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# Webhook signing secret (Stripe dashboard → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Packeta / Zásilkovna ────────────────────────────────────────────────────
NUXT_PUBLIC_PACKETA_API_KEY=
NUXT_PACKETA_API_SECRET=

# ─── SMTP (transactional emails) ─────────────────────────────────────────────
# Leave SMTP_HOST empty in dev to no-op emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Shopik <noreply@shopik.cz>"

# ─── Bank transfer (SPAYD QR code) ───────────────────────────────────────────
# Leave BANK_ACCOUNT_IBAN empty to hide bank-transfer QR (order still gets created).
# Example CZ format (no spaces): CZ6508000000192000145399
BANK_ACCOUNT_IBAN=
BANK_ACCOUNT_HOLDER="Tynky Bordel"

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
